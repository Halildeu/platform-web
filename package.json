{
  "name": "frontend",
  "version": "1.0.0",
  "description": "MFE Kök Dizini",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/mfe-reporting",
    "apps/mfe-shell",
    "apps/mfe-suggestions",
    "apps/mfe-ethic",
    "apps/mfe-access",
    "apps/mfe-audit",
    "apps/mfe-users",
    "packages/shared-http",
    "packages/ui-kit",
    "packages/shared-types",
    "packages/i18n-dicts"
  ],
  "main": "index.js",
  "scripts": {
    "prestart": "npx kill-port 3000 3001 3002 3003 3004 3005 3006 3007 || true",
    "dev:remotes": "bash ./scripts/ci/start-remotes.sh",
    "dev:shell": "npm start --prefix apps/mfe-shell",
    "dev:users": "npm start --prefix apps/mfe-users",
    "dev:access": "npm start --prefix apps/mfe-access",
    "dev:audit": "npm start --prefix apps/mfe-audit",
    "dev:all": "npm-run-all --parallel dev:shell dev:users dev:access dev:audit",
    "start": "concurrently \"npm start --prefix apps/mfe-shell\" \"npm start --prefix apps/mfe-suggestions\" \"npm start --prefix apps/mfe-ethic\" \"npm start --prefix packages/ui-kit\" \"npm start --prefix apps/mfe-users\" \"npm start --prefix apps/mfe-access\" \"npm start --prefix apps/mfe-audit\" \"npm start --prefix apps/mfe-reporting\"",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name build-storybook",
    "clean": "rimraf dist",
    "tokens:build": "node ./scripts/theme/generate-theme-css.mjs",
    "designlab:index": "python3 scripts/build_design_lab_index.py",
    "lint:style": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
    "lint:semantic": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:tailwind": "node ./scripts/lint/check-tailwind-semantic.mjs",
    "build:shell": "npm run build --prefix apps/mfe-shell",
    "build:suggestions": "npm run build --prefix apps/mfe-suggestions",
    "build:ethic": "npm run build --prefix apps/mfe-ethic",
    "build:access": "npm run build --prefix apps/mfe-access",
    "build:audit": "npm run build --prefix apps/mfe-audit",
    "build:ui-kit": "npm run build --prefix packages/ui-kit",
    "build:users": "npm run build --prefix apps/mfe-users",
    "build:reporting": "npm run build --prefix apps/mfe-reporting",
    "build": "npm run clean && npm-run-all --parallel build:*",
    "test": "npm-run-all test:shell test:suggestions test:ethic test:access test:audit test:ui-kit test:users test:reporting test:shared-types",
    "test:shell": "npm run test --prefix apps/mfe-shell",
    "test:suggestions": "npm run test --prefix apps/mfe-suggestions",
    "test:ethic": "npm run test --prefix apps/mfe-ethic",
    "test:access": "npm run test --prefix apps/mfe-access",
    "test:audit": "npm run test --prefix apps/mfe-audit",
    "test:ui-kit": "npm run test --prefix packages/ui-kit",
    "test:users": "npm run test --prefix apps/mfe-users",
    "test:reporting": "npm run test --prefix apps/mfe-reporting",
    "test:shared-types": "npm run test --prefix packages/shared-types",
    "test:shared-http": "pnpm --filter @mfe/shared-http test",
    "test:e2e:users": "npx playwright test tests/playwright/admin-users.auth.spec.ts",
    "test:e2e": "cypress run",
    "test:e2e:auth-sync": "npx playwright test tests/playwright/auth.sync.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:a11y": "npx playwright test tests/playwright/axe/axe.smoke.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "cypress:reports": "cypress run --spec \"cypress/e2e/reports-routing.cy.ts,cypress/e2e/reports-audit-deeplink.cy.ts,cypress/e2e/variants/global-default.cy.ts,cypress/e2e/users/permissions-inline.cy.ts\"",
    "smoke:playwright": "npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/reporting.a11y.spec.ts tests/playwright/access.toast.spec.ts tests/playwright/shell.i18n.spec.ts",
    "pw:ci": "PW_MODE=ci npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/scenario-runner.spec.ts --project=chromium --workers=1",
    "pw:nightly": "PW_MODE=nightly npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/scenario-runner.spec.ts --project=chromium --workers=1",
    "quality:audit:build": "npm run build:audit",
    "test:bundle": "size-limit",
    "test:perf": "lhci autorun --config=apps/mfe-audit/lighthouserc.json",
    "test:a11y": "axe --tags wcag2a,wcag2aa --exit 1 apps/mfe-audit/dist/index.html",
    "test:quality": "npm run quality:audit:build && npm run test:bundle && npm run test:perf && npm run test:a11y",
    "i18n:pull": "npm run pull --prefix packages/i18n-dicts",
    "i18n:pull:ci": "npm run pull:ci --prefix packages/i18n-dicts",
    "i18n:pull:dry": "npm run pull:dry --prefix packages/i18n-dicts",
    "i18n:pseudo": "npm run generate:pseudo --prefix packages/i18n-dicts",
    "security:sri:check": "node ./scripts/security/verify-sri.mjs --check --output security-reports/sri/report.json",
    "security:sri:rotate": "node ./scripts/security/verify-sri.mjs --write",
    "security:csp:summary": "node ./scripts/security/aggregate-csp.mjs --output security-reports/csp/summary.json",
    "storybook": "storybook dev -p 6006",
    "lint:no-antd": "node ./scripts/check-no-antd.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Halildeu/frontend.git"
  },
  "bugs": {
    "url": "https://github.com/Halildeu/frontend/issues"
  },
  "homepage": "https://github.com/Halildeu/frontend#readme",
  "devDependencies": {
    "@axe-core/cli": "^4.8.2",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@size-limit/file": "^11.1.4",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-onboarding": "^10.0.7",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react-webpack5": "^10.0.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "chromatic": "^13.3.3",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.2",
    "cypress": "^14.5.1",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "html-webpack-plugin": "^5.6.3",
    "kill-port": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.4",
    "storybook": "^10.0.7",
    "style-loader": "^4.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.47.0",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "lucide-react": "^0.554.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "react-redux": "^9.2.0",
    "react-router": "^6.27.0",
    "react-router-dom": "^6.27.0"
  },
  "overrides": {
    "ag-grid-community": "34.3.1",
    "ag-grid-enterprise": "34.3.1",
    "ag-grid-react": "34.3.1"
  },
  "size-limit": [
    {
      "name": "mfe-audit remote",
      "path": "apps/mfe-audit/dist/remoteEntry.js",
      "limit": "400 KB"
    }
  ]
}

{
  "name": "frontend",
  "version": "1.0.0",
  "description": "MFE Kök Dizini",
  "private": true,
  "engines": {
    "node": "20.x || 22.x"
  },
  "workspaces": [
    "apps/mfe-reporting",
    "apps/mfe-shell",
    "apps/mfe-suggestions",
    "apps/mfe-ethic",
    "apps/mfe-access",
    "apps/mfe-audit",
    "apps/mfe-users",
    "apps/docs",
    "packages/shared-http",
    "packages/design-system",
    "packages/shared-types",
    "packages/i18n-dicts",
    "packages/blocks",
    "packages/create-app",
    "packages/platform-capabilities",
    "packages/x-charts",
    "packages/x-data-grid",
    "packages/x-editor",
    "packages/x-form-builder",
    "packages/x-kanban",
    "packages/x-scheduler"
  ],
  "main": "index.js",
  "scripts": {
    "prestart": "npx kill-port 3000 3001 3002 3003 3004 3005 3006 3007 || true",
    "dev:remotes": "bash ./scripts/health/run-dev-servers.sh --profile remotes",
    "dev:shell": "npm start --prefix apps/mfe-shell",
    "dev:users": "npm start --prefix apps/mfe-users",
    "dev:access": "npm start --prefix apps/mfe-access",
    "dev:audit": "npm start --prefix apps/mfe-audit",
    "dev:all:raw": "npm-run-all --parallel dev:shell dev:users dev:access dev:audit",
    "dev:all": "bash ./scripts/health/run-dev-servers.sh --profile core",
    "dev:routes:start": "WEB_RUNTIME_PROFILE=auth-business-routes WEB_RUNTIME_TAIL=0 VITE_SHELL_ENABLE_SUGGESTIONS_REMOTE=0 SHELL_ENABLE_SUGGESTIONS_REMOTE=0 VITE_SHELL_ENABLE_ETHIC_REMOTE=0 SHELL_ENABLE_ETHIC_REMOTE=0 bash ./scripts/health/run-dev-servers.sh --profile auth-business-routes",
    "dev:routes:stop": "bash ./scripts/health/stop-dev-servers.sh",
    "start:raw": "npx concurrently \"npm start --prefix apps/mfe-shell\" \"npm start --prefix apps/mfe-suggestions\" \"npm start --prefix apps/mfe-ethic\" \"npm start --prefix apps/mfe-users\" \"npm start --prefix apps/mfe-access\" \"npm start --prefix apps/mfe-audit\" \"npm start --prefix apps/mfe-reporting\"",
    "start": "bash ./scripts/health/run-dev-servers.sh --profile full",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name build-storybook",
    "clean": "rimraf dist",
    "tokens:build": "node ./scripts/tokens/build-tokens.mjs",
    "tokens:build:theme": "node ./scripts/theme/generate-theme-css.mjs",
    "tokens:validate": "node ./scripts/tokens/validate-tokens.mjs",
    "changelog": "node scripts/ci/generate-changelog.mjs",
    "migration-guide": "node scripts/ci/generate-migration-guide.mjs",
    "component-diff": "node scripts/ci/component-diff.mjs",
    "ci:detect-breaking": "node scripts/ci/detect-breaking.mjs",
    "ci:publish-gate": "node ./scripts/ci/publish-gate.mjs",
    "ci:visual-diff": "node ./scripts/ci/visual-diff-check.mjs",
    "designlab:index": "python3 scripts/build_design_lab_index.py",
    "lint:style": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
    "lint:semantic": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:tailwind": "node ./scripts/lint/check-tailwind-semantic.mjs",
    "build:shell": "npm run build --prefix apps/mfe-shell",
    "build:suggestions": "npm run build --prefix apps/mfe-suggestions",
    "build:ethic": "npm run build --prefix apps/mfe-ethic",
    "build:access": "npm run build --prefix apps/mfe-access",
    "build:audit": "npm run build --prefix apps/mfe-audit",
    "build:design-system": "npm run build --prefix packages/design-system",
    "publish:bundle": "node ./scripts/ops/publish-ui-library-bundle.mjs",
    "release:ui-library:manifest": "node ./scripts/ops/generate-ui-library-release-manifest.mjs",
    "audit:ui-library-upgrade-recipes": "node ./scripts/ops/audit-ui-library-upgrade-recipes.mjs",
    "audit:ui-library-codemod-candidates": "node ./scripts/ops/audit-ui-library-codemod-candidates.mjs",
    "audit:ui-library-codemod-prototypes": "node ./scripts/ops/audit-ui-library-codemod-prototypes.mjs",
    "run:ui-library-codemod-dry-run": "node ./scripts/ops/run-ui-library-codemod-dry-run.mjs",
    "audit:ui-library-codemod-dry-run": "node ./scripts/ops/audit-ui-library-codemod-dry-run.mjs",
    "run:ui-library-codemod-apply-preview": "node ./scripts/ops/run-ui-library-codemod-apply-preview.mjs",
    "audit:ui-library-codemod-apply-preview": "node ./scripts/ops/audit-ui-library-codemod-apply-preview.mjs",
    "run:ui-library-codemod-manual-review": "node ./scripts/ops/run-ui-library-codemod-manual-review.mjs",
    "audit:ui-library-codemod-manual-review": "node ./scripts/ops/audit-ui-library-codemod-manual-review.mjs",
    "run:ui-library-codemod-manual-review-decisions": "node ./scripts/ops/run-ui-library-codemod-manual-review-decisions.mjs",
    "audit:ui-library-codemod-manual-review-decisions": "node ./scripts/ops/audit-ui-library-codemod-manual-review-decisions.mjs",
    "run:ui-library-codemod-apply": "node ./scripts/ops/run-ui-library-codemod-apply.mjs",
    "audit:ui-library-codemod-apply": "node ./scripts/ops/audit-ui-library-codemod-apply.mjs",
    "gate:ui-library-i18n-coverage": "npm run report:coverage --prefix packages/i18n-dicts",
    "gate:ui-library-i18n-pseudo": "npm run generate:pseudo --prefix packages/i18n-dicts && npm run check:pseudo-smoke --prefix packages/i18n-dicts",
    "gate:ui-library-i18n": "python3 ../scripts/check_ui_library_i18n_surface.py && python3 ../scripts/check_ui_library_i18n_code_refs.py",
    "gate:ui-library-visual": "python3 ../scripts/check_ui_library_visual_contract.py",
    "gate:ui-library-wave": "node ./scripts/ops/run-ui-library-wave-gate.mjs",
    "gate:ui-library-release": "node ./scripts/ops/run-ui-library-release-gate.mjs",
    "release:ui-library": "node ./scripts/ops/run-ui-library-release.mjs",
    "build:users": "npm run build --prefix apps/mfe-users",
    "build:reporting": "npm run build --prefix apps/mfe-reporting",
    "build:raw": "npm run clean && npm-run-all --parallel build:shell build:suggestions build:ethic build:access build:audit build:design-system build:users build:reporting",
    "build": "bash ./scripts/health/run-web-build-guard.sh --script build:raw",
    "test": "npm-run-all test:shell test:ethic test:access:unit test:audit test:design-system test:shared-types",
    "test:shell": "npm run test --prefix apps/mfe-shell",
    "test:ethic": "npm run test --prefix apps/mfe-ethic",
    "test:access:unit": "npm run test:unit --prefix apps/mfe-access",
    "test:audit": "npm run test --prefix apps/mfe-audit",
    "test:design-system": "npm run test --prefix packages/design-system",
    "test:users": "npm run test --prefix apps/mfe-users",
    "test:shared-types": "npm run test --prefix packages/shared-types",
    "test:shared-http": "pnpm --filter @mfe/shared-http test",
    "build:x-suite": "pnpm --filter '@mfe/x-*' build",
    "test:x-suite": "pnpm --filter '@mfe/x-*' test",
    "typecheck:x-suite": "pnpm --filter '@mfe/x-*' typecheck",
    "bench": "pnpm -r --parallel run bench",
    "bench:x-suite": "pnpm --filter '@mfe/x-*' run bench",
    "test:create-app": "pnpm --filter '@mfe/create-app' test",
    "test:blocks": "pnpm --filter '@mfe/blocks' test",
    "build:docs": "pnpm --filter '@mfe/docs' build",
    "lint": "pnpm -r --parallel run lint 2>/dev/null; npm run lint:style; npm run lint:semantic",
    "typecheck": "pnpm --filter '@mfe/design-system' --filter '@mfe/x-charts' --filter '@mfe/x-data-grid' --filter '@mfe/x-editor' --filter '@mfe/x-form-builder' --filter '@mfe/x-kanban' --filter '@mfe/x-scheduler' --filter '@mfe/create-app' --filter '@mfe/blocks' typecheck",
    "test:all": "npm-run-all test test:x-suite test:create-app",
    "build:all": "npm-run-all build:design-system build:x-suite build:docs",
    "verify": "npm-run-all typecheck test:all build:all",
    "verify:full": "npm-run-all typecheck test:all build:all test:blocks",
    "verify:release": "npm-run-all typecheck test:all build:all test:blocks lint:docs-truth",
    "lint:docs-truth": "node scripts/lint-docs-truth.mjs",
    "test:e2e:users": "npx playwright test tests/playwright/admin-users.auth.spec.ts",
    "test:e2e": "cypress run",
    "test:e2e:auth-sync": "npx playwright test tests/playwright/auth.sync.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:a11y:smoke": "npx playwright test tests/playwright/axe/axe.smoke.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:smoke:grid-pagination": "npx playwright test tests/playwright/grid.pagination.runtime.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:smoke:grid-pagination:stack": "node ./scripts/ops/run-with-frontend-stack.mjs --stack auth-business-routes -- npm run test:smoke:grid-pagination",
    "test:smoke:access-audit-pagination": "npx playwright test tests/playwright/access_audit.grid.pagination.runtime.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:smoke:access-audit-pagination:stack": "node ./scripts/ops/run-with-frontend-stack.mjs --stack auth-business-routes-live -- npm run test:smoke:access-audit-pagination",
    "test:smoke:real-mutations": "npx playwright test tests/playwright/dev_mutation_smoke.spec.ts --config tests/playwright/playwright.config.ts --project=chromium --workers=1",
    "test:smoke:real-mutations:stack": "node ./scripts/ops/run-with-frontend-stack.mjs --stack auth-business-routes-live -- npm run test:smoke:real-mutations",
    "test:smoke:business-routes": "npm run test:smoke:grid-pagination && npm run test:smoke:access-audit-pagination",
    "test:smoke:business-routes:stack": "npm run test:smoke:grid-pagination:stack && npm run test:smoke:access-audit-pagination:stack",
    "test:smoke:business-routes:full": "npm run test:smoke:business-routes && npm run test:smoke:real-mutations",
    "test:smoke:business-routes:full:stack": "npm run test:smoke:business-routes:stack && npm run test:smoke:real-mutations:stack",
    "report:mutation-lane-summary": "node ./scripts/ops/generate-mutation-lane-summary.mjs",
    "report:runtime-status-summary": "node ./scripts/ops/generate-runtime-status-summary.mjs",
    "cypress:reports": "cypress run --spec \"cypress/e2e/reports-routing.cy.ts,cypress/e2e/reports-audit-deeplink.cy.ts,cypress/e2e/variants/global-default.cy.ts,cypress/e2e/users/permissions-inline.cy.ts\"",
    "smoke:playwright": "npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/reporting.a11y.spec.ts tests/playwright/access.toast.spec.ts tests/playwright/shell.i18n.spec.ts",
    "pw:ci": "PW_MODE=ci npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/scenario-runner.spec.ts --project=chromium --workers=1",
    "pw:nightly": "PW_MODE=nightly npx playwright test --config tests/playwright/playwright.config.ts tests/playwright/scenario-runner.spec.ts --project=chromium --workers=1",
    "doctor:frontend": "node ./scripts/ops/frontend-doctor.mjs",
    "quality:audit:build": "npm run build:audit",
    "test:bundle": "size-limit",
    "test:perf": "lhci autorun --config=apps/mfe-audit/lighthouserc.json",
    "test:a11y": "axe --tags wcag2a,wcag2aa --exit 1 apps/mfe-audit/dist/index.html",
    "test:quality": "npm run quality:audit:build && npm run test:bundle && npm run test:perf && npm run test:a11y",
    "i18n:pull": "npm run pull --prefix packages/i18n-dicts",
    "i18n:pull:ci": "npm run pull:ci --prefix packages/i18n-dicts",
    "i18n:pull:dry": "npm run pull:dry --prefix packages/i18n-dicts",
    "i18n:pseudo": "npm run generate:pseudo --prefix packages/i18n-dicts",
    "security:sri:check": "node ./scripts/security/verify-sri.mjs --check --output security-reports/sri/report.json",
    "security:sri:rotate": "node ./scripts/security/verify-sri.mjs --write",
    "security:csp:summary": "node ./scripts/security/aggregate-csp.mjs --output security-reports/csp/summary.json",
    "storybook": "storybook dev -p 6006",
    "lint:no-antd": "node ./scripts/check-no-antd.mjs",
    "e2e": "playwright test",
    "e2e:visual": "playwright test e2e/visual/",
    "e2e:interaction": "playwright test e2e/interaction/",
    "e2e:responsive": "playwright test e2e/responsive/",
    "e2e:a11y": "playwright test e2e/accessibility/",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Halildeu/frontend.git"
  },
  "bugs": {
    "url": "https://github.com/Halildeu/frontend/issues"
  },
  "homepage": "https://github.com/Halildeu/frontend#readme",
  "devDependencies": {
    "@axe-core/cli": "^4.8.2",
    "@axe-core/playwright": "^4.11.1",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@size-limit/file": "^11.1.4",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-onboarding": "^10.0.7",
    "@storybook/addon-themes": "^10.3.0",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@storybook/react-webpack5": "^10.0.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "chromatic": "^13.3.3",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.2",
    "cypress": "^14.5.1",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "html-webpack-plugin": "^5.6.3",
    "kill-port": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.4",
    "storybook": "^10.3.0",
    "style-loader": "^4.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.47.0",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "lucide-react": "^0.554.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "react-redux": "^9.2.0",
    "react-router": "^6.27.0",
    "react-router-dom": "^6.27.0",
    "shiki": "^4.0.2"
  },
  "overrides": {
    "ag-grid-community": "34.3.1",
    "ag-grid-enterprise": "34.3.1",
    "ag-grid-react": "34.3.1",
    "baseline-browser-mapping": "2.10.0",
    "browserslist": "4.28.1",
    "caniuse-lite": "1.0.30001777",
    "update-browserslist-db": "1.2.3"
  },
  "pnpm": {
    "overrides": {
      "ag-grid-community": "34.3.1",
      "ag-grid-enterprise": "34.3.1",
      "ag-grid-react": "34.3.1",
      "baseline-browser-mapping": "2.10.0",
      "browserslist": "4.28.1",
      "caniuse-lite": "1.0.30001777",
      "update-browserslist-db": "1.2.3"
    }
  },
  "size-limit": [
    {
      "name": "mfe-audit remote",
      "path": "apps/mfe-audit/dist/remoteEntry.js",
      "limit": "400 KB"
    }
  ]
}

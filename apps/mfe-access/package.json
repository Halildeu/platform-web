    "@tanstack/react-query-devtools": "^5.90.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.13.0",
    "@mfe/i18n-dicts": "*",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "postcss-loader": "^8.1.1",
    "react-test-renderer": "18.2.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3",
    "tsx": "^4.20.6",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"

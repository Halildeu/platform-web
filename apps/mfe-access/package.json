{
  "name": "mfe-access",
  "version": "0.1.0",
  "description": "Access yönetimi mikro-frontend i",
  "main": "dist/remoteEntry.js",
  "scripts": {
    "start": "npx kill-port 3005 || true && webpack serve --config webpack.dev.js --no-watch-options-stdin",
    "build": "webpack --mode=production --config webpack.prod.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "npm run test:unit && npm run build",
    "test:unit": "tsx --tsconfig ./tsconfig.json --test src/app/App.test.ts src/widgets/access-management/ui/AccessFilterBar.test.tsx src/widgets/access-management/ui/AccessVariantToolbar.test.tsx src/widgets/access-management/ui/BulkPermissionModal.test.tsx src/widgets/access-management/ui/RoleCloneModal.test.tsx src/widgets/access-management/ui/AccessRoleDrawer.test.tsx src/widgets/access-management/ui/AccessGrid.test.tsx src/widgets/permission-registry/PermissionRegistryPanel.test.tsx"
  },
  "dependencies": {
    "@mfe/shared-http": "*",
    "@tanstack/react-query": "^5.90.10",
    "@mfe/shared-types": "*",
    "@mfe/design-system": "*",
    "ag-grid-community": "34.3.1",
    "ag-grid-enterprise": "34.3.1",
    "ag-grid-react": "34.3.1",
    "axios": "^1.7.7",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "react-router": "^6.27.0",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",

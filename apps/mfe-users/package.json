    "@mfe/shared-http": "*",
    "@mfe/shared-types": "*",
    "@mfe/i18n-dicts": "*",
    "@mfe/design-system": "*",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.90.10",
    "ag-grid-community": "34.3.1",
    "ag-grid-enterprise": "34.3.1",
    "ag-grid-react": "34.3.1",
    "axios": "^1.7.7",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "react-redux": "^9.2.0",
    "react-router": "^6.27.0",

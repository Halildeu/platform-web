{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "mfe-ui-kit": ["packages/ui-kit/src/index.ts"],
      "mfe-ui-kit/*": ["packages/ui-kit/src/*"],
      "mfe_shell": ["apps/mfe-shell/src/app/index.tsx"],
      "mfe_shell/*": ["apps/mfe-shell/src/*"],
      "@mfe/shared-types": ["packages/shared-types/src/index.ts"],
      "@mfe/shared-types/*": ["packages/shared-types/src/*"],
      "@mfe/i18n-dicts": ["packages/i18n-dicts/src/index.ts"],
      "@mfe/i18n-dicts/*": ["packages/i18n-dicts/src/*"]
    },
    "types": ["node", "jest", "cypress", "@testing-library/jest-dom"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/**/*.js",
    "apps/**/*.jsx",
    "apps/**/*.mjs",
    "apps/**/*.cjs",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.js",
    "packages/**/*.jsx",
    "packages/**/*.mjs",
    "packages/**/*.cjs",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    "stories/**/*.js",
    "stories/**/*.jsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "tests/**/*.js",
    "tests/**/*.jsx",
    "scripts/**/*.ts",
    "scripts/**/*.tsx",
    "scripts/**/*.js",
    "scripts/**/*.jsx",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs",
    "cypress/**/*.ts",
    "cypress/**/*.tsx",
    "cypress/**/*.js",
    "cypress/**/*.jsx",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "docs/**/*.js",
    "docs/**/*.jsx",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.mjs"
  ]
}

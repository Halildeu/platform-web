{
  "name": "@mfe/x-data-grid",
  "version": "0.1.0",
  "private": true,
  "description": "Internal workspace package — not published to registry",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Halildeu/platform-ssot.git",
    "directory": "web/packages/x-data-grid"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench",
    "test:e2e": "playwright test",
    "test:perf": "vitest bench"
  },
  "peerDependencies": {
    "@mfe/design-system": "*",
    "ag-grid-community": "^34.0.0",
    "ag-grid-enterprise": "^34.0.0",
    "ag-grid-react": "^34.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.0.0"
  }
}

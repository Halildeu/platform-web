{
  "name": "@mfe/design-system",
  "version": "1.0.0",
  "type": "module",
  "description": "Unified design system — tokens, theme, primitives, components, patterns, advanced",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/esm/tokens/index.js",
      "require": "./dist/cjs/tokens/index.cjs"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/esm/primitives/index.js",
      "require": "./dist/cjs/primitives/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/esm/components/index.js",
      "require": "./dist/cjs/components/index.cjs"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/esm/patterns/index.js",
      "require": "./dist/cjs/patterns/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/esm/providers/index.js",
      "require": "./dist/cjs/providers/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/esm/theme/index.js",
      "require": "./dist/cjs/theme/index.cjs"
    },
    "./a11y": {
      "types": "./dist/a11y/index.d.ts",
      "import": "./dist/esm/a11y/index.js",
      "require": "./dist/cjs/a11y/index.cjs"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/esm/performance/index.js",
      "require": "./dist/cjs/performance/index.cjs"
    },
    "./headless": {
      "types": "./dist/headless/index.d.ts",
      "import": "./dist/esm/headless/index.js",
      "require": "./dist/cjs/headless/index.cjs"
    },
    "./headless/overlay": {
      "types": "./dist/internal/overlay-engine/index.d.ts",
      "import": "./dist/esm/internal/overlay-engine/index.js",
      "require": "./dist/cjs/internal/overlay-engine/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/esm/icons/index.js",
      "require": "./dist/cjs/icons/index.cjs"
    },
    "./advanced": {
      "types": "./dist/advanced/index.d.ts",
      "import": "./dist/esm/advanced/index.js",
      "require": "./dist/cjs/advanced/index.cjs"
    },
    "./advanced/data-grid/setup": {
      "types": "./dist/advanced/data-grid/setup.d.ts",
      "import": "./dist/esm/advanced/data-grid/setup.js",
      "require": "./dist/cjs/advanced/data-grid/setup.cjs"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/esm/form/index.js",
      "require": "./dist/cjs/form/index.cjs"
    },
    "./motion": {
      "types": "./dist/motion/index.d.ts",
      "import": "./dist/esm/motion/index.js",
      "require": "./dist/cjs/motion/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/esm/server.js",
      "require": "./dist/cjs/server.cjs"
    },
    "./unstable/interaction-core": {
      "types": "./dist/internal/interaction-core/index.d.ts",
      "import": "./dist/esm/internal/interaction-core/index.js",
      "require": "./dist/cjs/internal/interaction-core/index.cjs"
    },
    "./unstable/overlay-engine": {
      "types": "./dist/internal/overlay-engine/index.d.ts",
      "import": "./dist/esm/internal/overlay-engine/index.js",
      "require": "./dist/cjs/internal/overlay-engine/index.cjs"
    },
    "./lib/auth": {
      "types": "./src/lib/auth/index.ts",
      "default": "./src/lib/auth/index.ts"
    },
    "./advanced/data-grid/TablePagination": {
      "types": "./src/advanced/data-grid/TablePagination.d.ts",
      "default": "./src/advanced/data-grid/TablePagination.tsx"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "sideEffects": [
    "./src/advanced/data-grid/setup.ts",
    "*.css",
    "./dist/esm/advanced/data-grid/setup.js",
    "./dist/cjs/advanced/data-grid/setup.cjs"
  ],
  "scripts": {
    "start": "storybook dev -p 6006",
    "scaffold:component": "node scripts/scaffold-component.mjs",
    "build": "rm -rf dist && tsup && npx tsc --project tsconfig.build.json && node scripts/post-build-use-client.mjs",
    "lint": "../../node_modules/.bin/eslint --config eslint.config.mjs src",
    "test": "vitest run",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "build:tokens": "node style-dictionary.config.mjs",
    "build:tokens:legacy": "node scripts/build-tokens.mjs",
    "migration-guide": "node scripts/generate-migration-guide.mjs",
    "api-diff": "node scripts/component-diff.mjs",
    "docs:api": "node scripts/generate-api-reference.mjs",
    "docs:update-metrics": "node scripts/ci/update-docs-metrics.mjs",
    "typecheck": "tsc --noEmit",
    "check:component-completeness": "node scripts/ci/component-completeness.mjs",
    "check:authoring": "npm run check:component-completeness && npm run lint",
    "audit": "node scripts/ci/component-audit.mjs",
    "audit:ci": "node scripts/ci/component-audit.mjs --ci",
    "audit:json": "node scripts/ci/component-audit.mjs --json",
    "test:generate-contracts": "node scripts/ci/generate-contract-tests.mjs --write",
    "test:missing-contracts": "node scripts/ci/generate-contract-tests.mjs --diff",
    "test:quality": "node scripts/ci/test-quality-analyzer.mjs",
    "test:quality:shallow": "node scripts/ci/test-quality-analyzer.mjs --shallow",
    "test:quality:ci": "node scripts/ci/test-quality-analyzer.mjs --ci",
    "test:mutate": "npx stryker run",
    "test:mutate:enterprise": "npx stryker run --mutate 'src/enterprise/**/*.tsx'",
    "test:mutate:gate": "node scripts/ci/mutation-gate.mjs",
    "test:mutate:gate:ci": "node scripts/ci/mutation-gate.mjs --ci",
    "scorecard": "node scripts/ci/component-scorecard.mjs",
    "scorecard:json": "node scripts/ci/component-scorecard.mjs --json",
    "scorecard:ci": "node scripts/ci/component-scorecard.mjs --ci",
    "scorecard:dashboard": "node scripts/ci/component-scorecard.mjs --json && node scripts/ci/scorecard-dashboard.mjs",
    "lint:ci": "../../node_modules/.bin/eslint --config eslint.config.mjs src --max-warnings 0",
    "test:coverage": "vitest run --coverage",
    "semver-check": "node scripts/ci/semver-check.mjs",
    "quality": "npm run typecheck && npm run lint:ci && npm run audit:ci && npm run test:quality:ci && npm run test && npm run scorecard:ci",
    "perf-benchmark": "node scripts/ci/perf-benchmark.mjs",
    "changelog": "node scripts/ci/changelog-gen.mjs",
    "quality:full": "npm run typecheck && npm run lint:ci && npm run audit:ci && npm run test:quality:ci && npm run test && npm run test:a11y-gate:ci && npm run token-audit:ci && npm run dark-fallback-gate:ci && npm run license-audit:ci && npm run keyboard-matrix && npm run docs:api && npm run semver-check && npm run perf-benchmark && npm run scorecard:ci",
    "quality:reports": "npm run scorecard:json && npm run scorecard:dashboard && npm run bundle-report && npm run changelog && npm run docs:api",
    "test:a11y-gate": "node scripts/ci/a11y-gate.mjs",
    "test:a11y-gate:ci": "node scripts/ci/a11y-gate.mjs --ci",
    "quality:release": "node scripts/ci/quality-gate.mjs",
    "quality:release:visual": "node scripts/ci/quality-gate.mjs --visual",
    "license-audit": "node scripts/ci/license-audit.mjs",
    "license-audit:ci": "node scripts/ci/license-audit.mjs --ci",
    "bundle-report": "node scripts/ci/bundle-analyzer.mjs",
    "pr-review": "node scripts/ci/pr-design-review.mjs",
    "pr-review:test": "node scripts/ci/pr-design-review.mjs --test",
    "pr-review:legacy": "node scripts/ci/ai-pr-review.mjs",
    "pr-review:ci": "node scripts/ci/ai-pr-review.mjs --ci",
    "predict": "node scripts/ci/component-predictor.mjs",
    "a11y-guardian": "node scripts/ci/a11y-guardian.mjs",
    "a11y-guardian:ci": "node scripts/ci/a11y-guardian.mjs --ci",
    "token-audit": "node scripts/ci/token-audit.mjs",
    "token-audit:ci": "node scripts/ci/token-audit.mjs --ci",
    "keyboard-matrix": "node scripts/ci/keyboard-matrix.mjs",
    "dark-fallback-gate": "node scripts/ci/dark-fallback-gate.mjs",
    "dark-fallback-gate:ci": "node scripts/ci/dark-fallback-gate.mjs --ci",
    "prepack": "[ -d dist ] || npm run build",
    "prepublishOnly": "npm run build",
    "figma:generate-stubs": "node ../../scripts/generate-figma-connect-stubs.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@tanstack/react-query": "^5.90.10",
    "ag-charts-community": "12.3.1",
    "ag-charts-enterprise": "12.3.1",
    "ag-charts-react": "12.3.1",
    "ag-grid-community": "34.3.1",
    "ag-grid-enterprise": "34.3.1",
    "ag-grid-react": "34.3.1",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@mfe/shared-http": "*",
    "@mfe/shared-types": "*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@mfe/shared-http": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "@mfe/shared-types": {
      "optional": true
    }
  }
}

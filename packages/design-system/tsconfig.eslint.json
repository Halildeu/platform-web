{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mfe/shared-types": ["../shared-types/src/index.ts"],
      "@mfe/shared-types/*": ["../shared-types/src/*"],
      "@mfe/shared-http": ["../shared-http/src/index.ts"],
      "@mfe/shared-http/*": ["../shared-http/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__visual__/**"
  ]
}

    "@tiptap/extension-table-cell": { "optional": true },
    "@tiptap/extension-table-header": { "optional": true },
    "@tiptap/extension-mention": { "optional": true },
    "@tiptap/extension-placeholder": { "optional": true },
    "@tiptap/extension-underline": { "optional": true },
    "@tiptap/extension-code-block-lowlight": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.0.0"

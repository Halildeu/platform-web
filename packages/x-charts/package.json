{
  "name": "@mfe/x-charts",
  "version": "0.1.0",
  "private": true,
  "packageStrategy": "internal-platform",
  "internal": true,
  "description": "Internal platform package — not published to npm",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Halildeu/platform-ssot.git",
    "directory": "web/packages/x-charts"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./ssr": {
      "types": "./src/ssr/index.ts",
      "import": "./src/ssr/index.ts",
      "default": "./src/ssr/index.ts"
    },
    "./benchmark": {
      "types": "./src/performance/benchmark/index.ts",
      "import": "./src/performance/benchmark/index.ts",
      "default": "./src/performance/benchmark/index.ts"
    }
  },
  "files": [
    "src",
    "CONTRACT.md",
    "README.md"
  ],
  "scripts": {
    "build": "echo source-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "echo source-only",
    "bench": "vitest bench"
  },
  "sideEffects": [
    "**/*.css",
    "./src/i18n/locale-store.ts"
  ],
  "dependencies": {
    "@mfe/shared-types": "*",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "echarts-gl": "^2.0.9",
    "echarts-liquidfill": "~3.1.0",
    "echarts-wordcloud": "~2.1.0",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  }
}

VITE_MANIFEST_BASE=/manifest/v1
# MANIFEST_BASE_URL=/manifest/v1

# AG Grid Enterprise lisans anahtarı (frontend bundle içine gömülür; repo'ya koymayın)
# Tek-kaynak: VITE_AG_GRID_LICENSE_KEY (CI'da GitHub Secret AG_GRID_LICENSE_KEY
# build-arg olarak bu isimle inject edilir; runtime'da tek bundle key'i bu).
# VITE_AG_GRID_LICENSE_KEY=

# Sentry error tracking (optional — leave empty to disable)
# VITE_SENTRY_DSN=
